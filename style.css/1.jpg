*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Prompt',sans-serif;
}

body{

    background:linear-gradient(135deg,#d8f3ff,#eefcff);

    min-height:100vh;

    overflow-x:hidden;

}

/* พื้นหลัง */

.bg-animation{

    position:fixed;

    width:100%;

    height:100%;

    overflow:hidden;

    z-index:-1;

}

.bg-animation span{

    position:absolute;

    bottom:-120px;

    width:40px;

    height:40px;

    background:rgba(255,255,255,.5);

    border-radius:50%;

    animation:float 18s linear infinite;

}

.bg-animation span:nth-child(1){left:8%; animation-duration:14s;}
.bg-animation span:nth-child(2){left:20%; width:70px;height:70px;}
.bg-animation span:nth-child(3){left:35%; animation-duration:20s;}
.bg-animation span:nth-child(4){left:50%; width:60px;height:60px;}
.bg-animation span:nth-child(5){left:65%;}
.bg-animation span:nth-child(6){left:78%; animation-duration:24s;}
.bg-animation span:nth-child(7){left:88%; width:80px;height:80px;}
.bg-animation span:nth-child(8){left:96%; animation-duration:16s;}

@keyframes float{

0%{

transform:translateY(0) scale(0);

opacity:0;

}

30%{

opacity:.7;

}

100%{

transform:translateY(-120vh) scale(2);

opacity:0;

}

}

.container{

width:90%;

max-width:1100px;

margin:auto;

padding:40px 20px;

}

/* Header */

header{

text-align:center;

background:rgba(255,255,255,.35);

backdrop-filter:blur(12px);

border-radius:30px;

padding:40px;

box-shadow:0 10px 30px rgba(0,0,0,.1);

}

.profile{

width:180px;

height:180px;

border-radius:50%;

border:6px solid white;

object-fit:cover;

box-shadow:0 10px 25px rgba(0,0,0,.15);

}

h1{

margin-top:20px;

color:#347aa8;

font-size:42px;

}

.subtitle{

margin-top:10px;

font-size:18px;

color:#4f7188;

}

/* เมนู */

nav{

margin-top:35px;

display:flex;

justify-content:center;

gap:18px;

flex-wrap:wrap;

}

nav a{

text-decoration:none;

padding:13px 28px;

background:white;

border-radius:50px;

color:#2d7eb9;

font-weight:600;

transition:.35s;

}

nav a:hover{

background:#7ecbff;

color:white;

transform:translateY(-5px);

box-shadow:0 10px 20px rgba(0,0,0,.15);

}

/* เนื้อหา */

.welcome{

margin-top:45px;

background:white;

padding:45px;

border-radius:25px;

box-shadow:0 15px 30px rgba(0,0,0,.08);

text-align:center;

}

.welcome h2{

font-size:34px;

color:#2c7ab8;

margin-bottom:20px;

}

.welcome p{

font-size:18px;

line-height:1.9;

color:#555;

}

.button{

display:inline-block;

margin-top:35px;

padding:15px 35px;

background:#69c3ff;

color:white;

text-decoration:none;

border-radius:40px;

font-size:18px;

transition:.3s;

}

.button:hover{

background:#409fe0;

transform:scale(1.05);

}

/* Responsive */

@media(max-width:768px){

h1{

font-size:30px;

}

.profile{

width:150px;

height:150px;

}

nav{

flex-direction:column;

}

nav a{

width:100%;

}

.welcome{

padding:30px;

}

}
